{
  "manifest_version": 3,
  "name": "Hacker Extension",
  "version": "0.0.1",
  "description": "外链管理神器，快速填充预设文本和外链信息。",
  "action": {
    "default_title": "Hacker Extension"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.notion.com/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/recorderBridge.ts-loader-CyllNq5q.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "assets/recorderInjected.ts-BXyPAaDp.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "assets/main.tsx-loader-DCg59Bc_.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-K5Eyp34J.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/capture-DH_tnSBr.js",
        "assets/recorderBridge.ts-D-4gjh8m.js",
        "assets/recorderInjected.ts-BXyPAaDp.js",
        "assets/jsx-runtime-D0XvMYhy.js",
        "assets/storage-2OXClUq6.js",
        "assets/main.tsx-BhZHomc1.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
