{
  "manifest_version": 3,
  "name": "Hacker Extension",
  "version": "0.1.0",
  "description": "出海助手 - 找词、找站、数据、外链一站式解决方案",
  "action": {
    "default_title": "Hacker Extension",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "nativeMessaging",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.notion.com/*",
    "https://sim.3ue.co/*",
    "https://sem.3ue.co/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/recorderBridge.ts-loader-B_wa7UZj.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "assets/recorderInjected.ts-BI9MNVNM.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "assets/simProxyBridge.ts-loader-eZZa33LD.js"
      ],
      "matches": [
        "https://sim.3ue.co/*",
        "https://sem.3ue.co/*"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "assets/simProxyInjected.ts-loader-DNq_2tNK.js"
      ],
      "matches": [
        "https://sim.3ue.co/*",
        "https://sem.3ue.co/*"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "assets/main.tsx-loader-BGlKBv-s.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-K5Eyp34J.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/capture-B7vBTewh.js",
        "assets/recorderBridge.ts-D95VkiDC.js",
        "assets/recorderInjected.ts-BI9MNVNM.js",
        "assets/jsx-runtime-D0XvMYhy.js",
        "assets/storage-Cp1NEoAh.js",
        "assets/main.tsx-Ba7tdjYS.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://sem.3ue.co/*",
        "https://sim.3ue.co/*"
      ],
      "resources": [
        "assets/simProxy-D4sL0i6_.js",
        "assets/simProxyBridge.ts-hSTz5xQf.js",
        "assets/simProxyInjected.ts-DLoRFkX8.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
