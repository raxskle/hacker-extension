{
  "manifest_version": 3,
  "name": "Hacker Extension",
  "version": "0.0.1",
  "description": "外链管理神器，快速填充预设文本和外链信息。",
  "action": {
    "default_title": "Hacker Extension"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.notion.com/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/recorderBridge.ts-loader-DCifJE7k.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "assets/main.tsx-loader-C4kq_UGb.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-K5Eyp34J.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/content/recorderInjected.ts",
        "assets/capture-B7G2CUKj.js",
        "assets/recorderBridge.ts-CkLLSMkD.js",
        "assets/jsx-runtime-D0XvMYhy.js",
        "assets/storage-Sv-J-bvU.js",
        "assets/main.tsx-Bp73kaSH.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
