{
  "manifest_version": 3,
  "name": "Hacker Extension",
  "version": "0.1.0",
  "description": "出海助手 - 找词、找站、数据、外链一站式解决方案",
  "action": {
    "default_title": "Hacker Extension",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.notion.com/*",
    "https://sim.3ue.co/*",
    "https://sem.3ue.co/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/recorderBridge.ts-loader-B8fSp0A6.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "assets/recorderInjected.ts-BI9MNVNM.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "assets/simProxyBridge.ts-loader-dSRbZuHJ.js"
      ],
      "matches": [
        "https://sim.3ue.co/*",
        "https://sem.3ue.co/*"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "assets/simProxyInjected.ts-loader-CR9fDPjC.js"
      ],
      "matches": [
        "https://sim.3ue.co/*",
        "https://sem.3ue.co/*"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "assets/main.tsx-loader-CNaugAUB.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/main-K5Eyp34J.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/capture-BsYPYRW5.js",
        "assets/recorderBridge.ts-BC8ms8l3.js",
        "assets/recorderInjected.ts-BI9MNVNM.js",
        "assets/jsx-runtime-D0XvMYhy.js",
        "assets/storage-DOpb9BAS.js",
        "assets/main.tsx-Dt-cLQs3.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://sem.3ue.co/*",
        "https://sim.3ue.co/*"
      ],
      "resources": [
        "assets/simProxy-PKUfKNHf.js",
        "assets/simProxyBridge.ts-DCCAFRbZ.js",
        "assets/simProxyInjected.ts-BXI1P6Lw.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
